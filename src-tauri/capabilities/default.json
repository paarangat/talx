{
  "$schema": "https://raw.githubusercontent.com/nicegui-org/nicegui/main/nicegui/static/tauri/capabilities-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the main window",
  "windows": ["main", "settings"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "core:tray:default",
    "core:menu:default",
    "core:window:default",
    "core:window:allow-start-dragging"
  ]
}
